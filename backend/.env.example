# Server
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Auth
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Anthropic Claude AI  (REQUIRED - get at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Database (SQLite path - auto created)
DB_PATH=./db/viraliq.sqlite

# Optional: Social Media API Keys for real-time data
# If not set, the backend uses smart mock data
TWITTER_BEARER_TOKEN=
YOUTUBE_API_KEY=
INSTAGRAM_ACCESS_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
